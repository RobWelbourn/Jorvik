{
  "tasks": {
    "dev": "deno run --watch main.ts",
    "test": "cd tests && deno test -A"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1",
    "@std/cli": "jsr:@std/cli@^1.0.28",
    "@std/path": "jsr:@std/path@^1.1.4",
    "json5": "npm:json5@^2.2.3",
    "typebox": "npm:typebox@^1.1.6"
  },
  "name": "@jorvik/jorvik",
  "version": "0.3.0",
  "description": "Configuration management for TypeScript apps",
  "license": "MIT",
  "exports": {
    "./cli": "./src/cli.ts",
    "./configmgr": "./src/configmgr.ts",
    "./result": "./src/result.ts",
    "./typeboxhelpers": "./src/typeboxhelpers.ts"
  },
  "fmt": {
    "indentWidth": 4,
    "lineWidth": 120,
    "useTabs": false,
    "singleQuote": true,
    "operatorPosition": "maintain"
  }
}
